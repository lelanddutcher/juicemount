# JuiceMount server-side stack configuration.
# Copy to .env and fill in REQUIRED fields before `docker compose up`.

# --- REQUIRED ---
# MinIO root password. Generate a strong one — this is the master key
# for the entire object store, AND becomes the JuiceFS secret-key.
# Anyone with this password can read/write every byte in the volume.
# Example: openssl rand -base64 24
MINIO_ROOT_PASSWORD=

# --- Optional (sensible defaults below) ---

# MinIO root username. Default 'juicemount' is fine for self-hosting;
# change if you're running multiple MinIO instances on the same host.
MINIO_ROOT_USER=juicemount

# Ports. Change if these collide with other services on the host.
MINIO_S3_PORT=9000
MINIO_CONSOLE_PORT=9001
REDIS_PORT=6379
NFS_PORT=2049
ADMIN_PORT=11050

# Data paths. These are bind-mounts into the containers. Use absolute
# paths on production hosts (e.g. /mnt/ssd/juicemount/minio) so the
# data lives on your fast storage, not in the docker-compose dir.
# Defaults are relative to the compose file for the quick-start case.
MINIO_DATA_DIR=./data/minio
REDIS_DATA_DIR=./data/redis
# JuiceMount server's SQLite metadata + pin store
JM_DATA_DIR=./data/jm

# JuiceMount server's local SSD chunk cache size in MB. The default
# 100000 (= 100 GB) is generous; reduce if your host has less SSD.
# JuiceFS will trim the cache LRU-style under disk pressure.
JM_CACHE_SIZE_MB=100000

# --- Caddy / TLS / admin API (iter 3, B.5) ---

# Hostname Caddy listens on. localhost works for local-quickstart
# with a self-signed cert. Set to a real DNS name (e.g. juicemount.example.com)
# to enable ACME / Let's Encrypt — also requires changing
# `tls internal` to `tls your@email` in Caddyfile.
JM_HOSTNAME=localhost

# Admin-key gates POSTs to /api/* (pin/unpin/cache-clear/stop etc).
# Generate one with: openssl rand -hex 32
# Clients must send: X-JuiceMount-Admin-Key: <this-value>
# Anyone with this key can stop the server, clear cache, unpin
# everything — treat it like a root password.
ADMIN_KEY=

# Ports for the Caddy edge. Change if 443/80 are already in use.
CADDY_HTTPS_PORT=443
CADDY_HTTP_PORT=80

# Caddy's persistent data + config dirs. Stores ACME certs here once
# you switch off self-signed.
CADDY_DATA_DIR=./data/caddy
CADDY_CONFIG_DIR=./data/caddy-config

# JuiceFS volume layout.
# JUICEFS_BUCKET   — name of the MinIO bucket holding the data.
# JUICEFS_VOL_NAME — human name for the JuiceFS volume; appears in
#                    `juicefs status` output and mount commands.
# Once set on first run these become part of the formatted volume —
# changing them later requires a re-format (data loss).
JUICEFS_BUCKET=zpool
JUICEFS_VOL_NAME=zpool
