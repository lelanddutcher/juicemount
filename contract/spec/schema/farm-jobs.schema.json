{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lelanddutcher/juicemount-contract/spec/schema/farm-jobs.schema.json",
  "title": "GET /farm/jobs — farm worker presence + recent jobs (response)",
  "description": "The producer's read-back view. `available` = ≥1 active worker draining (so the UI can say 'the farm is generating' vs 'queued, waiting for a worker'). Counts are serialized as typed JSON ints even though the worker keeps a stringified Redis HASH internally.",
  "type": "object",
  "required": ["available", "workers", "queue_depth", "jobs"],
  "properties": {
    "available": { "type": "boolean" },
    "queue_depth": { "type": "integer" },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "started_at": { "type": "string" },
          "last_seen": { "type": "string" },
          "current_job": { "type": ["string", "null"] }
        }
      }
    },
    "jobs": {
      "type": "array",
      "description": "Recent-first.",
      "items": {
        "type": "object",
        "required": ["id", "status", "path", "kinds", "producer"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string", "enum": ["queued", "running", "done", "failed"] },
          "path": { "type": "string" },
          "kinds": { "type": "string", "description": "Comma-joined request set." },
          "producer": { "type": "string", "enum": ["openloupe", "manager"] },
          "enqueued_at": { "type": "string" },
          "started_at": { "type": "string" },
          "finished_at": { "type": "string" },
          "processed": { "type": "integer" },
          "failed": { "type": "integer" },
          "error": { "type": "string" }
        }
      }
    }
  }
}
