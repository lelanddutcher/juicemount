# Binaries
# (Don't use a bare `jm5` pattern — that matches cmd/jm5/main.go too,
# silently un-tracking the headless CLI source. Anchor to repo root.)
/jm5
/juicemount
*.a
*.dylib
*.so

# macOS
.DS_Store
._*

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test artifacts
/tmp/
*.log

# Build output
/build/*.a
/build/*.h
/build/JuiceMount.app/
app/JuiceMount/.build/

# SQLite databases (local state, not code)
*.db
*.db-wal
*.db-shm

# Credentials / infrastructure docs (not code)
credentials.md

# Claude Code
.claude/
