# Binaries
# (Don't use a bare `jm5` pattern — that matches cmd/jm5/main.go too,
# silently un-tracking the headless CLI source. Anchor to repo root.)
/jm5
/juicemount
# Loop-A test tools, built+copied to repo root for convenience
/jmstress
/jmcompare
/jmwatch
*.a
*.dylib
*.so

# macOS
.DS_Store
._*

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test artifacts
/tmp/
*.log

# Build output
/build/*.a
/build/*.h
/build/JuiceMount.app/
/build/AppIcon.iconset/
/build/sparkle-release/
app/JuiceMount/.build/

# SQLite databases (local state, not code)
*.db
*.db-wal
*.db-shm

# Credentials / infrastructure docs (not code)
credentials.md

# Local secrets + real-credential configs — never commit (your machine only).
# The committed server/docker-compose.yml uses a CHANGEME placeholder; the
# *.local.yml copy holds your actual passwords/paths for deployment.
secrets/
*.local.yml
*.local.yaml

# Claude Code
.claude/
/build/svg2png

# Internal planning / business / vision docs — NOT for the public repo.
# These stay on the maintainer's machine; only user- and contributor-facing
# docs (README, LICENSE, NOTICE, CHANGELOG, ARCHITECTURE, server/, docs/
# dev-setup|signing|no-fileprovider|PERFORMANCE_METHODOLOGY) ship publicly.
# (A NEW, public-facing ROADMAP.md is intentionally NOT ignored.)
/VISION/
/docs/ROADMAP/
/docs/TUNING/
/docs/COMPETITIVE/
/docs/screenshots/
/docs/STATE.md
/docs/OPEN_BUGS.md
/docs/LAUNCH_PLAN.md
/docs/HANDOFF_truenas_connectx_flapping.md
/docs/README_DRAFT.md
/docs/VISION.md
/docs/QA-procedure.md
