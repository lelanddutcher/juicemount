<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.juicemount.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Applications/JuiceMount.app/Contents/MacOS/JuiceMount</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ProcessType</key>
    <string>Interactive</string>

    <key>StandardOutPath</key>
    <string>/tmp/juicemount.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/juicemount.err</string>

    <!-- Throttle: don't relaunch more than once per 10 seconds -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Limit memory to keep the menu bar app lightweight even under leaks -->
    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>10240</integer>
    </dict>
</dict>
</plist>
